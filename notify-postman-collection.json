                        },
                        {
                            "name": "422 Unprocessable – Validation Error",
                            "originalRequest": {
                                "method": "POST",
                                "header": [
                                    {
                                        "key": "X-API-Key",
                                        "value": "{{api_key}}"
                                    },
                                    {
                                        "key": "Content-Type",
                                        "value": "application/json"
                                    }
                                ],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"to_email\": \"not-an-email\"\n}"
                                },
                                "url": {
                                    "raw": "{{base_url}}/api/mail/sendmail",
                                    "host": ["{{base_url}}"],
                                    "path": ["api", "mail", "sendmail"]
                                }
                            },
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "_postman_previewlanguage": "json",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n    \"message\": \"The to email field must be a valid email address.\",\n    \"errors\": {\n        \"to_email\": [\n            \"The to email field must be a valid email address.\"\n        ],\n        \"from_email\": [\n            \"The from email field is required.\"\n        ],\n        \"from_name\": [\n            \"The from name field is required.\"\n        ],\n        \"subject\": [\n            \"The subject field is required.\"\n        ],\n        \"body_html\": [\n            \"The body html field is required.\"\n        ]\n    }\n}"
                        }
                    ]
                },
